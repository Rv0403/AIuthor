# Groq — fast / cheap agents (intent, writer, editor, fact_checker, evals)

GROQ_API_KEY=your_groq_key



# Google Gemini — reasoning, grounded search, embeddings

GEMINI_API_KEY=your_gemini_key



LLM_PROVIDER=groq_gemini



# Which provider handles each capability

CHEAP_PROVIDER=groq

STRONG_PROVIDER=groq

REASONING_PROVIDER=gemini

GROUNDED_PROVIDER=gemini



# Groq models (free tier at console.groq.com)

GROQ_CHEAP_MODEL=llama-3.1-8b-instant

GROQ_STRONG_MODEL=llama-3.3-70b-versatile



# Gemini models (free tier at aistudio.google.com)

GEMINI_CHEAP_MODEL=gemini-2.0-flash

GEMINI_STRONG_MODEL=gemini-2.0-flash

GEMINI_REASONING_MODEL=gemini-2.5-flash

GEMINI_GROUNDED_MODEL=gemini-2.0-flash



EMBEDDING_PROVIDER=gemini

EMBEDDING_MODEL=text-embedding-004



# Optional LangSmith tracing

LANGCHAIN_API_KEY=

LANGCHAIN_TRACING_V2=false

LANGCHAIN_PROJECT=aiuthor



# Offline tests with no API keys

MOCK_LLM=false

