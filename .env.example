# Groq — fast agents (intent, writer, editor, fact_checker, evals)
GROQ_API_KEY=your_groq_key

# Gemini — embeddings only (Option C: all text agents on Groq)
GEMINI_API_KEY=your_gemini_key

# Provider routing per capability (Option C: Groq for text, Gemini for embeddings)
CHEAP_PROVIDER=groq
STRONG_PROVIDER=groq
REASONING_PROVIDER=groq
GROUNDED_PROVIDER=groq

# Groq models (console.groq.com)
GROQ_CHEAP_MODEL=llama-3.1-8b-instant
GROQ_STRONG_MODEL=llama-3.3-70b-versatile

# Gemini models (aistudio.google.com)
GEMINI_CHEAP_MODEL=gemini-2.0-flash
GEMINI_STRONG_MODEL=gemini-2.0-flash
GEMINI_REASONING_MODEL=gemini-2.5-flash
GEMINI_GROUNDED_MODEL=gemini-2.0-flash
EMBEDDING_MODEL=gemini-embedding-001

# Optional LangSmith tracing
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=aiuthor

# Offline tests with no API keys
MOCK_LLM=false
